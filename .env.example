APP_ENV=development
APP_TIMEZONE=America/New_York
DEPLOYMENT_MODE=laptop

DEV_MODE=true
SIMULATE_SMS=true

SMS_PROVIDER=dev
USER_PHONE_NUMBER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
REQUIRE_TWILIO_SIGNATURE_VALIDATION=true

DATABASE_URL=sqlite:///./data/time_secretary.db
REPORTS_DIR=./reports
BACKUPS_DIR=./backups

START_SCHEDULER=false
ACTIVE_START_TIME=06:00
ACTIVE_END_TIME=22:00
CHECKIN_INTERVAL_MINUTES=15
CHECKIN_REPLY_GRACE_MINUTES=45

DAILY_REPORT_TIME=21:30
WEEKLY_REPORT_DAY=Sunday
WEEKLY_REPORT_TIME=20:00
MONTHLY_REPORT_TIME=20:30

SEND_REPORTS_BY_SMS=true
SAVE_REPORTS_TO_DISK=true
QUIET_MODE=false

BACKUP_ENABLED=true
BACKUP_TIME=03:00
BACKUP_RETENTION_DAYS=60

LLM_ENABLED=false
LLM_PROVIDER=none
LLM_MODEL=
LLM_BASE_URL=http://localhost:11434
LLM_TIMEOUT_SECONDS=20
LLM_MAX_INPUT_CHARS=2500
LLM_USE_FOR_LOW_CONFIDENCE_ONLY=true
LLM_REQUIRE_JSON=true
LLM_SAVE_RAW_RESPONSES=false
LLM_REDACT_PHONE_NUMBERS=true
LLM_ALLOW_WORK_NOTES=false

SECURE_CAPTURE_ENABLED=true
SECURE_CAPTURE_TOKEN=
SECURE_CAPTURE_ALLOW_LLM=false
LOG_SECURE_CAPTURE_BODY=false
TAILSCALE_ONLY_MODE=true
EXPORT_INCLUDE_SENSITIVE=false
INCLUDE_SENSITIVE_LOCAL_REPORTS=false

BRIEFINGS_ENABLED=true
BRIEFING_DEFAULT_WINDOW_DAYS=30
BRIEFING_SMS_LINK_ONLY=true
BRIEFING_USE_OPAQUE_IDS=true
BRIEFING_INCLUDE_SENSITIVE_DEFAULT=false
BRIEFING_REPORTS_DIR=./reports/briefings
BRIEFING_PUBLIC_BASE_URL=
BRIEFING_TAILSCALE_BASE_URL=

LLM_REPORTS_ENABLED=false
LLM_REPORT_PROVIDER=ollama
LLM_REPORT_MODEL=llama3.2:3b
LLM_REPORT_FALLBACK_MODEL=
LLM_REPORT_TIMEOUT_SECONDS=90
LLM_REPORT_MAX_INPUT_CHARS=12000
LLM_REPORT_MAX_OUTPUT_TOKENS=1200
LLM_REPORT_TEMPERATURE=0.2
LLM_REPORT_USE_STRUCTURED_OUTPUT=true
LLM_REPORT_CACHE_ENABLED=true
LLM_REPORT_BACKGROUND_GENERATION=true
LLM_REPORT_VALIDATE_CLAIMS=true

DEFAULT_REVIEW_MORNING=08:00
DEFAULT_REVIEW_AFTERNOON=15:00
DEFAULT_REVIEW_EVENING=19:00
DEFAULT_EOD_REVIEW_TIME=21:30
